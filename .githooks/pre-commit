#!/usr/bin/env bash
# Thin dispatcher to scripts/lint.sh --hook.
# All check logic (format, windows-hdr, license, opengrep, optional clang-tidy)
# lives in scripts/lint.sh so it stays runnable on demand outside the git hook.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
exec "$REPO_ROOT/scripts/lint.sh" --hook

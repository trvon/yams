{
  "name": "search_tiered_ablation",
  "description": "Product hybrid (topology off): enableTieredExecution on vs off. Product ablation showed no_tiered +~0.02 MRR.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 3600,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "repeats": 3,
  "baseline": "tiered_on",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_BENCH_TOPOLOGY_MODE": "disabled"
    },
    "params": {
      "dataset": "scifact",
      "corpus_size": 2000,
      "num_queries": 50,
      "topk": 10
    }
  },
  "arms": [
    {
      "name": "tiered_on",
      "factors": { "parallel_tiered": "on" },
      "env": { "YAMS_SEARCH_ENABLE_TIERED_EXECUTION": "1" }
    },
    {
      "name": "tiered_off",
      "factors": { "parallel_tiered": "off" },
      "env": { "YAMS_SEARCH_ENABLE_TIERED_EXECUTION": "0" }
    }
  ],
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": [
        "mrr",
        "ndcg_at_k",
        "map",
        "recall_at_k",
        "search_latency_ms_p50",
        "search_latency_ms_p95"
      ]
    }
  ],
  "validate": {
    "require_files": ["metrics.json", "stdout.log"],
    "require_metrics": ["mrr"],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": [
      "mrr",
      "ndcg_at_k",
      "map",
      "search_latency_ms_p50",
      "search_latency_ms_p95"
    ]
  }
}

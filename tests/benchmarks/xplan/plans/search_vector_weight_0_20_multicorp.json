{
  "name": "search_vector_weight_0_20_multicorp",
  "description": "Product topology+ANN hybrid: vectorWeight 0.30 vs 0.20 with text rebalance, scifact + nfcorpus (repeats=3).",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 10800,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "repeats": 3,
  "baseline": "scifact_v030",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_BENCH_TOPOLOGY_MODE": "hybrid_assist",
      "YAMS_BENCH_TOPOLOGY_VECTOR_POLICY": "shadow",
      "YAMS_BENCH_SKIP_BUILD": "1"
    },
    "params": {
      "topk": 10,
      "num_queries": 50,
      "skip_build": true
    }
  },
  "arms": [
    {
      "name": "scifact_v030",
      "factors": { "dataset": "scifact", "vector_weight": 0.30 },
      "params": { "dataset": "scifact", "corpus_size": 2000 },
      "env": {
        "YAMS_BENCH_DATASET": "scifact",
        "YAMS_BENCH_CORPUS_SIZE": "2000",
        "YAMS_SEARCH_VECTOR_WEIGHT": "0.30",
        "YAMS_SEARCH_TEXT_WEIGHT": "0.70"
      }
    },
    {
      "name": "scifact_v020",
      "factors": { "dataset": "scifact", "vector_weight": 0.20 },
      "params": { "dataset": "scifact", "corpus_size": 2000 },
      "env": {
        "YAMS_BENCH_DATASET": "scifact",
        "YAMS_BENCH_CORPUS_SIZE": "2000",
        "YAMS_SEARCH_VECTOR_WEIGHT": "0.20",
        "YAMS_SEARCH_TEXT_WEIGHT": "0.80"
      }
    },
    {
      "name": "nfcorpus_v030",
      "factors": { "dataset": "nfcorpus", "vector_weight": 0.30 },
      "params": { "dataset": "nfcorpus", "corpus_size": 0 },
      "env": {
        "YAMS_BENCH_DATASET": "nfcorpus",
        "YAMS_SEARCH_VECTOR_WEIGHT": "0.30",
        "YAMS_SEARCH_TEXT_WEIGHT": "0.70"
      }
    },
    {
      "name": "nfcorpus_v020",
      "factors": { "dataset": "nfcorpus", "vector_weight": 0.20 },
      "params": { "dataset": "nfcorpus", "corpus_size": 0 },
      "env": {
        "YAMS_BENCH_DATASET": "nfcorpus",
        "YAMS_SEARCH_VECTOR_WEIGHT": "0.20",
        "YAMS_SEARCH_TEXT_WEIGHT": "0.80"
      }
    }
  ],
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": [
        "mrr",
        "ndcg_at_k",
        "map",
        "recall_at_k",
        "search_latency_ms_p50",
        "search_latency_ms_p95"
      ]
    }
  ],
  "validate": {
    "require_files": ["metrics.json", "stdout.log"],
    "require_metrics": ["mrr"],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": [
      "mrr",
      "ndcg_at_k",
      "map",
      "search_latency_ms_p50",
      "search_latency_ms_p95"
    ],
    "group_by": ["dataset"]
  }
}

{
  "name": "leg_stage_ablation",
  "description": "Single-engine-lane Phase-3 LOO: baseline vs one-leg-off and one-stage-off, on a BEIR dataset with repeats. Each removal delta is judged vs its repeat variance to decide prune/keep. Change `dataset` to sweep scifact/nfcorpus/fiqa.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 5400,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "repeats": 3,
  "baseline": "full",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_EMBED_BACKEND": "simeon"
    },
    "params": {
      "dataset": "scifact",
      "corpus_size": 2000,
      "num_queries": 50,
      "topk": 10,
      "embed_backend": "simeon",
      "rerank_topk": 10
    }
  },
  "arms": [
    { "name": "full", "factors": { "ablate": "none" } },
    { "name": "text_off", "factors": { "ablate": "text", "text": "off" } },
    { "name": "simeon_off", "factors": { "ablate": "simeon_text", "simeon_text": "off" } },
    { "name": "graph_text_off", "factors": { "ablate": "graph_text", "graph_text": "off" } },
    { "name": "vector_off", "factors": { "ablate": "vector", "vector": "off" } },
    { "name": "kg_off", "factors": { "ablate": "kg_weight", "kg_weight": "off" } },
    { "name": "rerank_off", "factors": { "ablate": "rerank", "rerank": "off" } },
    { "name": "graph_rerank_off", "factors": { "ablate": "graph_rerank", "graph_rerank": "off" } },
    { "name": "concept_boost_off", "factors": { "ablate": "concept_boost", "concept_boost": "off" } }
  ],
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": ["ndcg_at_k", "recall_at_k"]
    }
  ],
  "validate": {
    "require_files": ["metrics.json"],
    "require_metrics": ["ndcg_at_k"],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": ["ndcg_at_k", "recall_at_k", "mrr", "map"],
    "group_by": ["ablate"]
  }
}

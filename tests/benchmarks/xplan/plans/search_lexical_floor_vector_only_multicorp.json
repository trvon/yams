{
  "name": "search_lexical_floor_vector_only_multicorp",
  "description": "Lever-1 soft fusion package: pure dense is weak; lexical floor and vector-only guardrails matter. Product topology+ANN hybrid; scifact+nfcorpus n=3.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 10800,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "repeats": 3,
  "baseline": "scifact_product",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_BENCH_TOPOLOGY_MODE": "hybrid_assist",
      "YAMS_BENCH_TOPOLOGY_VECTOR_POLICY": "shadow",
      "YAMS_BENCH_SKIP_BUILD": "1"
    },
    "params": {
      "topk": 10,
      "num_queries": 50,
      "skip_build": true
    }
  },
  "arms": [
    {
      "name": "scifact_product",
      "factors": { "dataset": "scifact", "package": "product" },
      "params": { "dataset": "scifact", "corpus_size": 2000 },
      "env": {
        "YAMS_BENCH_DATASET": "scifact",
        "YAMS_BENCH_CORPUS_SIZE": "2000"
      }
    },
    {
      "name": "scifact_lex_floor_strong",
      "factors": { "dataset": "scifact", "package": "lex_floor_strong" },
      "params": { "dataset": "scifact", "corpus_size": 2000 },
      "env": {
        "YAMS_BENCH_DATASET": "scifact",
        "YAMS_BENCH_CORPUS_SIZE": "2000",
        "YAMS_SEARCH_LEXICAL_FLOOR_TOPN": "20",
        "YAMS_SEARCH_LEXICAL_FLOOR_BOOST": "0.30",
        "YAMS_SEARCH_VECTOR_ONLY_THRESHOLD": "0.96",
        "YAMS_SEARCH_VECTOR_ONLY_PENALTY": "0.60"
      }
    },
    {
      "name": "scifact_vector_only",
      "factors": { "dataset": "scifact", "package": "vector_only" },
      "params": { "dataset": "scifact", "corpus_size": 2000 },
      "env": {
        "YAMS_BENCH_DATASET": "scifact",
        "YAMS_BENCH_CORPUS_SIZE": "2000",
        "YAMS_SEARCH_TEXT_WEIGHT": "0.0",
        "YAMS_SEARCH_VECTOR_WEIGHT": "1.0",
        "YAMS_SEARCH_LEXICAL_FLOOR_TOPN": "0",
        "YAMS_SEARCH_LEXICAL_FLOOR_BOOST": "0.0"
      }
    },
    {
      "name": "nfcorpus_product",
      "factors": { "dataset": "nfcorpus", "package": "product" },
      "params": { "dataset": "nfcorpus", "corpus_size": 0 },
      "env": {
        "YAMS_BENCH_DATASET": "nfcorpus"
      }
    },
    {
      "name": "nfcorpus_lex_floor_strong",
      "factors": { "dataset": "nfcorpus", "package": "lex_floor_strong" },
      "params": { "dataset": "nfcorpus", "corpus_size": 0 },
      "env": {
        "YAMS_BENCH_DATASET": "nfcorpus",
        "YAMS_SEARCH_LEXICAL_FLOOR_TOPN": "20",
        "YAMS_SEARCH_LEXICAL_FLOOR_BOOST": "0.30",
        "YAMS_SEARCH_VECTOR_ONLY_THRESHOLD": "0.96",
        "YAMS_SEARCH_VECTOR_ONLY_PENALTY": "0.60"
      }
    },
    {
      "name": "nfcorpus_vector_only",
      "factors": { "dataset": "nfcorpus", "package": "vector_only" },
      "params": { "dataset": "nfcorpus", "corpus_size": 0 },
      "env": {
        "YAMS_BENCH_DATASET": "nfcorpus",
        "YAMS_SEARCH_TEXT_WEIGHT": "0.0",
        "YAMS_SEARCH_VECTOR_WEIGHT": "1.0",
        "YAMS_SEARCH_LEXICAL_FLOOR_TOPN": "0",
        "YAMS_SEARCH_LEXICAL_FLOOR_BOOST": "0.0"
      }
    }
  ],
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": [
        "mrr",
        "ndcg_at_k",
        "map",
        "recall_at_k",
        "search_latency_ms_p50",
        "search_latency_ms_p95"
      ]
    }
  ],
  "validate": {
    "require_files": ["metrics.json", "stdout.log"],
    "require_metrics": ["mrr"],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": [
      "mrr",
      "ndcg_at_k",
      "map",
      "search_latency_ms_p50",
      "search_latency_ms_p95"
    ],
    "group_by": ["dataset", "package"]
  }
}

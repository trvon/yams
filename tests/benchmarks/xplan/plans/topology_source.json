{
  "name": "topology_source",
  "description": "Topology artifact source \u00d7 expansion-arm matrix on BEIR scifact (vector/fts5/kg \u00d7 cap2/medoid64/rerank_only).",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 7200,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_BENCH_TOPOLOGY_ENGINE": "connected",
      "YAMS_BENCH_SEED_SEMANTIC_NEIGHBORS": "1",
      "YAMS_BENCH_TOPOLOGY_ROUTE_SCORING": "current",
      "YAMS_BENCH_TOPOLOGY_SPARSE_DENSE_ALPHA": "0.5",
      "YAMS_BENCH_TOPOLOGY_MIN_ROUTE_SCORE": "0",
      "YAMS_SEARCH_TOPOLOGY_MAX_CLUSTERS": "2"
    },
    "params": {
      "dataset": "scifact",
      "corpus_size": 2000,
      "num_queries": 50,
      "topk": 10,
      "topology_engine": "connected",
      "seed_semantic_neighbors": "1"
    }
  },
  "factors": {
    "topology_source": [
      "vector",
      "fts5",
      "kg"
    ],
    "expansion_arm": [
      "cap2",
      "medoid64",
      "rerank_only"
    ]
  },
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": [
        "mrr",
        "ndcg_at_k"
      ]
    }
  ],
  "validate": {
    "require_files": [
      "metrics.json",
      "stdout.log"
    ],
    "require_metrics": [
      "mrr"
    ],
    "require_metric_status": [
      "ok"
    ]
  },
  "summarize": {
    "primary": [
      "mrr",
      "ndcg_at_k",
      "topology_applied",
      "topology_added_avg",
      "topology_cert_ok",
      "hybrid_queries"
    ],
    "group_by": [
      "topology_source",
      "expansion_arm"
    ]
  }
}

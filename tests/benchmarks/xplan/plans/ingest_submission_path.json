{
  "name": "ingest_submission_path",
  "description": "Equal-corpus lossless ingestion gate: compare one recursive directory request with concurrent pipelined single-file requests while preserving complete searchability and enrichment.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 1200,
  "continue_on_arm_failure": true,
  "mode": "synthetic",
  "repeats": 3,
  "baseline": "directory",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1"
    },
    "params": {
      "corpus_size": 100,
      "doc_size": 1000,
      "poll_interval_ms": 100,
      "post_ingest_coalesce_ms": 2,
      "require_complete_pipeline": true,
      "require_full_searchability": true,
      "require_experiment_identity": true
    }
  },
  "arms": [
    {
      "name": "directory",
      "factors": {
        "ingest_mode": "directory",
        "ingest_concurrency": 1
      },
      "params": {
        "ingest_mode": "directory",
        "ingest_concurrency": 1
      }
    },
    {
      "name": "pipelined_single_file_c4",
      "factors": {
        "ingest_mode": "pipelined_single_file",
        "ingest_concurrency": 4
      },
      "params": {
        "ingest_mode": "pipelined_single_file",
        "ingest_concurrency": 4
      }
    }
  ],
  "steps": [
    {
      "worker": "ingestion_e2e",
      "metrics": [
        "total_duration_ms",
        "docs_per_s",
        "pipeline_complete",
        "dropped_batches",
        "post_ingest_coalesce_ms",
        "post_ingest_batch_size",
        "admission_ms",
        "storage_ready_ms",
        "pipeline_drain_ms",
        "enrichment_ready_ms",
        "searchability_ready_ms",
        "metadata_insert_writer_batches",
        "metadata_insert_writer_avg_batch_size",
        "metadata_insert_writer_queue_wait_avg_us",
        "metadata_insert_writer_queue_wait_max_us",
        "metadata_insert_writer_batch_apply_avg_us",
        "metadata_insert_writer_batch_apply_max_us",
        "metadata_insert_writer_connection_wait_estimated_avg_us",
        "metadata_insert_phase_timings_transaction_total_avg_us",
        "metadata_insert_writer_failed_batches",
        "metadata_insert_writer_fallback_items",
        "write_coordinator_batches_committed",
        "write_coordinator_commit_errors",
        "write_coordinator_max_queue_depth",
        "write_coordinator_capacity_rejections",
        "write_coordinator_max_batch_apply_ms",
        "write_coordinator_max_batch_queue_wait_ms"
      ]
    }
  ],
  "validate": {
    "require_files": ["metrics.json", "mode_manifest.json"],
    "require_metrics": [
      "total_duration_ms",
      "docs_per_s",
      "pipeline_complete",
      "dropped_batches",
      "post_ingest_coalesce_ms",
      "post_ingest_batch_size",
      "admission_ms",
      "storage_ready_ms",
      "pipeline_drain_ms",
      "searchability_ready_ms",
      "metadata_insert_writer_batches",
      "metadata_insert_writer_avg_batch_size",
      "metadata_insert_writer_batch_apply_avg_us",
      "metadata_insert_writer_connection_wait_estimated_avg_us",
      "metadata_insert_phase_timings_transaction_total_avg_us",
      "write_coordinator_batches_committed"
    ],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": [
      "docs_per_s",
      "total_duration_ms",
      "pipeline_complete",
      "dropped_batches",
      "post_ingest_coalesce_ms",
      "post_ingest_batch_size",
      "admission_ms",
      "storage_ready_ms",
      "pipeline_drain_ms",
      "enrichment_ready_ms",
      "searchability_ready_ms",
      "document_store_total_ms",
      "queue_max_store_document_tasks",
      "queue_max_post_ingest",
      "queue_max_embed_jobs",
      "post_ingest_batch_extraction_batches",
      "post_ingest_batch_content_index_calls",
      "post_ingest_batch_content_index_avg_entries_per_call",
      "post_ingest_batch_content_index_max_entries",
      "metadata_insert_writer_batches",
      "metadata_insert_writer_avg_batch_size",
      "metadata_insert_writer_max_batch_size",
      "metadata_insert_writer_queue_wait_avg_us",
      "metadata_insert_writer_queue_wait_max_us",
      "metadata_insert_writer_batch_apply_avg_us",
      "metadata_insert_writer_batch_apply_max_us",
      "metadata_insert_writer_connection_wait_estimated_total_us",
      "metadata_insert_writer_connection_wait_estimated_avg_us",
      "metadata_insert_phase_timings_transaction_total_total_us",
      "metadata_insert_phase_timings_transaction_total_avg_us",
      "metadata_insert_writer_failed_batches",
      "metadata_insert_writer_fallback_items",
      "write_coordinator_batches_enqueued",
      "write_coordinator_batches_committed",
      "write_coordinator_ops_applied",
      "write_coordinator_commit_errors",
      "write_coordinator_max_queue_depth",
      "write_coordinator_capacity_rejections",
      "write_coordinator_forced_enqueues_over_capacity",
      "write_coordinator_max_batch_apply_ms",
      "write_coordinator_max_batch_queue_wait_ms",
      "write_coordinator_max_batch_excess_queue_wait_ms"
    ],
    "group_by": ["ingest_mode", "ingest_concurrency"]
  }
}

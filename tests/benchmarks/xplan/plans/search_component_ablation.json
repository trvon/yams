{
  "name": "search_component_ablation",
  "description": "One-factor-off ablation of hybrid search components (weight=0 gates via YAMS_SEARCH_*_WEIGHT) on BEIR scifact. KPI-1 search lane for optimization ranking.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 3600,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_BENCH_TOPOLOGY_MODE": "hybrid_assist",
      "YAMS_BENCH_TOPOLOGY_ENGINE": "connected",
      "YAMS_BENCH_TOPOLOGY_SOURCE": "vector"
    },
    "params": {
      "dataset": "scifact",
      "corpus_size": 2000,
      "num_queries": 50,
      "topk": 10,
      "expansion_arm": "cap2"
    }
  },
  "arms": [
    {
      "name": "baseline",
      "factors": {
        "text": "on",
        "vector": "on",
        "kg_weight": "on",
        "graph_text": "on",
        "graph_vector": "on",
        "graph_rerank": "on",
        "rerank": "on",
        "topology": "on"
      }
    },
    {
      "name": "no_text",
      "factors": {
        "text": "off"
      },
      "params": {
        "text": "off"
      }
    },
    {
      "name": "no_vector",
      "factors": {
        "vector": "off"
      },
      "params": {
        "vector": "off"
      }
    },
    {
      "name": "no_kg",
      "factors": {
        "kg_weight": "off"
      },
      "params": {
        "kg_weight": "off"
      }
    },
    {
      "name": "no_graph_text",
      "factors": {
        "graph_text": "off"
      },
      "params": {
        "graph_text": "off"
      }
    },
    {
      "name": "no_graph_vector",
      "factors": {
        "graph_vector": "off"
      },
      "params": {
        "graph_vector": "off"
      }
    },
    {
      "name": "no_graph_rerank",
      "factors": {
        "graph_rerank": "off"
      },
      "params": {
        "graph_rerank": "off"
      }
    },
    {
      "name": "no_rerank",
      "factors": {
        "rerank": "off"
      },
      "params": {
        "rerank": "off"
      }
    },
    {
      "name": "no_topology",
      "factors": {
        "topology": "off"
      },
      "params": {
        "topology": "off"
      }
    }
  ],
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": [
        "mrr",
        "ndcg_at_k",
        "map"
      ]
    }
  ],
  "validate": {
    "require_files": [
      "metrics.json",
      "stdout.log"
    ],
    "require_metrics": [
      "mrr"
    ],
    "require_metric_status": [
      "ok"
    ]
  },
  "summarize": {
    "primary": [
      "mrr",
      "ndcg_at_k",
      "map",
      "recall_at_k",
      "precision_at_k",
      "hybrid_queries",
      "topology_applied"
    ]
  }
}

{
  "name": "search_graph_vector_weight_ablation",
  "description": "Product hybrid (topology off): lower graphVectorWeight (default 0.08). Complements vectorWeight ablation; scifact-only until multi-corpus gate passes.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 7200,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "repeats": 3,
  "baseline": "gv_w008",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_BENCH_TOPOLOGY_MODE": "disabled",
      "YAMS_BENCH_SKIP_BUILD": "1"
    },
    "params": {
      "dataset": "scifact",
      "corpus_size": 2000,
      "num_queries": 50,
      "topk": 10,
      "skip_build": true
    }
  },
  "arms": [
    {
      "name": "gv_w008",
      "factors": { "graph_vector_weight": 0.08 },
      "env": { "YAMS_SEARCH_GRAPH_VECTOR_WEIGHT": "0.08" }
    },
    {
      "name": "gv_w004",
      "factors": { "graph_vector_weight": 0.04 },
      "env": { "YAMS_SEARCH_GRAPH_VECTOR_WEIGHT": "0.04" }
    },
    {
      "name": "gv_w002",
      "factors": { "graph_vector_weight": 0.02 },
      "env": { "YAMS_SEARCH_GRAPH_VECTOR_WEIGHT": "0.02" }
    },
    {
      "name": "gv_w000",
      "factors": { "graph_vector_weight": 0.0 },
      "env": { "YAMS_SEARCH_GRAPH_VECTOR_WEIGHT": "0" }
    }
  ],
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": [
        "mrr",
        "ndcg_at_k",
        "map",
        "recall_at_k",
        "search_latency_ms_p50",
        "search_latency_ms_p95"
      ]
    }
  ],
  "validate": {
    "require_files": ["metrics.json", "stdout.log"],
    "require_metrics": ["mrr"],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": [
      "mrr",
      "ndcg_at_k",
      "map",
      "search_latency_ms_p50",
      "search_latency_ms_p95"
    ]
  }
}

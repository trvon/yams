{
  "name": "ingest_pipeline",
  "description": "Ingest ablation (one-factor-off): KG, vectors, GLiNER, and full minimal path for optimization ranking.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 900,
  "continue_on_arm_failure": true,
  "mode": "synthetic",
  "repeats": 3,
  "baseline": "baseline",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1"
    },
    "params": {
      "corpus_size": 100,
      "doc_size": 1000,
      "poll_interval_ms": 100,
      "post_ingest_coalesce_ms": 2,
      "ingest_mode": "directory",
      "ingest_concurrency": 1,
      "require_complete_pipeline": true,
      "require_full_searchability": true,
      "require_experiment_identity": true
    }
  },
  "arms": [
    {
      "name": "baseline",
      "factors": { "kg": "on", "vectors": "on", "gliner": "on" }
    },
    {
      "name": "no_kg",
      "factors": { "kg": "off", "vectors": "on", "gliner": "on" }
    },
    {
      "name": "no_vectors",
      "factors": { "kg": "on", "vectors": "off", "gliner": "on" }
    },
    {
      "name": "no_gliner",
      "factors": { "kg": "on", "vectors": "on", "gliner": "off" }
    },
    {
      "name": "no_vectors_no_kg",
      "factors": { "kg": "off", "vectors": "off", "gliner": "on" }
    },
    {
      "name": "minimal",
      "factors": { "kg": "off", "vectors": "off", "gliner": "off" }
    }
  ],
  "steps": [
    {
      "worker": "ingestion_e2e",
      "metrics": [
        "total_duration_ms",
        "docs_per_s",
        "pipeline_complete",
        "dropped_batches",
        "post_ingest_coalesce_ms",
        "post_ingest_batch_size",
        "admission_ms",
        "add_dispatch_avg_us",
        "add_dispatch_fingerprint_avg_us",
        "add_dispatch_enqueue_avg_us",
        "storage_ready_ms",
        "pipeline_drain_ms",
        "enrichment_ready_ms",
        "searchability_ready_ms",
        "write_coordinator_batches_committed",
        "write_coordinator_commit_errors",
        "write_coordinator_max_queue_depth",
        "write_coordinator_capacity_rejections",
        "write_coordinator_max_batch_apply_ms",
        "write_coordinator_max_batch_queue_wait_ms"
      ]
    }
  ],
  "validate": {
    "require_files": ["metrics.json", "mode_manifest.json"],
    "require_metrics": [
      "total_duration_ms",
      "docs_per_s",
      "pipeline_complete",
      "dropped_batches",
      "post_ingest_coalesce_ms",
      "post_ingest_batch_size",
      "admission_ms",
      "add_dispatch_avg_us",
      "add_dispatch_fingerprint_avg_us",
      "add_dispatch_enqueue_avg_us",
      "storage_ready_ms",
      "pipeline_drain_ms",
      "searchability_ready_ms",
      "write_coordinator_batches_committed"
    ],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": [
      "docs_per_s",
      "total_duration_ms",
      "pipeline_complete",
      "dropped_batches",
      "post_ingest_coalesce_ms",
      "post_ingest_batch_size",
      "admission_ms",
      "add_dispatch_samples",
      "add_dispatch_avg_us",
      "add_dispatch_fingerprint_avg_us",
      "add_dispatch_enqueue_avg_us",
      "storage_ready_ms",
      "pipeline_drain_ms",
      "enrichment_ready_ms",
      "searchability_ready_ms",
      "document_store_total_ms",
      "extract_ms",
      "kg_ms",
      "embed_prepare_ms",
      "queue_max_post_ingest",
      "queue_max_embed_jobs",
      "write_coordinator_batches_enqueued",
      "write_coordinator_batches_committed",
      "write_coordinator_ops_applied",
      "write_coordinator_commit_errors",
      "write_coordinator_max_queue_depth",
      "write_coordinator_capacity_rejections",
      "write_coordinator_forced_enqueues_over_capacity",
      "write_coordinator_max_batch_apply_ms",
      "write_coordinator_max_batch_queue_wait_ms",
      "write_coordinator_max_batch_excess_queue_wait_ms"
    ],
    "group_by": ["kg", "vectors", "gliner"]
  }
}

{
  "name": "search_generalized_memory_topology_gate",
  "description": "Single-index generalized-memory gate: SciFact and NF-Corpus coexist in one daemon; compare global ANN, hard topology narrowing, and additive topology-vector augmentation with per-cluster overlap and explicit quality/cost accounting.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 7200,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "repeats": 3,
  "baseline": "global_ann_c32",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_BENCH_SEED_SEMANTIC_NEIGHBORS": "1",
      "YAMS_BENCH_TOPOLOGY_ENGINE": "connected",
      "YAMS_TOPOLOGY_MIN_EDGE_SCORE": "0.25",
      "YAMS_TOPOLOGY_MAX_COMPONENT_DOCS": "64",
      "YAMS_VECTOR_MAX_RESULTS": "32",
      "YAMS_VECTOR_SEARCH_ENGINE": "vec0",
      "YAMS_VECTOR_VEC0_PHSS_ENABLED": "1"
    },
    "params": {
      "datasets": ["scifact", "nfcorpus"],
      "documents_per_dataset": 2000,
      "queries_per_dataset": 50,
      "topk": 10,
      "topology_source": "vector",
      "topology_engine": "connected",
      "require_steady_state": true,
      "seed_semantic_neighbors": "1",
      "max_component_docs": 64,
      "min_edge_score": 0.25
    }
  },
  "arms": [
    {
      "name": "global_ann_c32",
      "factors": {
        "topology_mode": "disabled",
        "ann_candidate_budget": 32,
        "vector_result_budget": 32
      },
      "env": {
        "YAMS_BENCH_TOPOLOGY_MODE": "disabled",
        "YAMS_VECTOR_VEC0_PHSS_CANDIDATES": "32"
      }
    },
    {
      "name": "routed_margin020_min1",
      "factors": {
        "topology_mode": "hybrid_assist",
        "topology_vector_policy": "narrow",
        "route_candidate_budget": 16,
        "adaptive_routing": true,
        "confidence_margin": 0.2,
        "min_clusters": 1
      },
      "env": {
        "YAMS_BENCH_TOPOLOGY_MODE": "hybrid_assist",
        "YAMS_BENCH_TOPOLOGY_VECTOR_POLICY": "narrow",
        "YAMS_VECTOR_VEC0_PHSS_CANDIDATES": "48"
      },
      "params": {
        "topology_vector_policy": "narrow",
        "min_clusters": 1,
        "max_clusters": 4,
        "max_docs": 16,
        "max_docs_per_cluster": 8,
        "max_seed_documents": 16,
        "adaptive_probe_score_gap": 0.05,
        "narrow_min_boundary_margin": 0.2,
        "min_route_score": 0.15
      }
    },
    {
      "name": "augmented_margin020_min1_c23",
      "factors": {
        "topology_mode": "hybrid_assist",
        "topology_vector_policy": "augment",
        "ann_candidate_budget": 23,
        "vector_result_budget": 23,
        "route_candidate_budget": 16,
        "adaptive_routing": true,
        "confidence_margin": 0.2,
        "min_clusters": 1
      },
      "env": {
        "YAMS_BENCH_TOPOLOGY_MODE": "hybrid_assist",
        "YAMS_BENCH_TOPOLOGY_VECTOR_POLICY": "augment",
        "YAMS_VECTOR_MAX_RESULTS": "23",
        "YAMS_VECTOR_VEC0_PHSS_CANDIDATES": "23"
      },
      "params": {
        "topology_vector_policy": "augment",
        "min_clusters": 1,
        "max_clusters": 4,
        "max_docs": 16,
        "max_docs_per_cluster": 8,
        "max_seed_documents": 16,
        "adaptive_probe_score_gap": 0.05,
        "narrow_min_boundary_margin": 0.2,
        "min_route_score": 0.15
      }
    }
  ],
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": [
        "mrr",
        "ndcg_at_k",
        "recall_at_k",
        "mixed_source_macro_mrr",
        "mixed_source_min_mrr",
        "mixed_source_macro_recall_at_k",
        "mixed_source_min_recall_at_k",
        "mixed_mrr_scifact",
        "mixed_mrr_nfcorpus",
        "mixed_recall_at_k_scifact",
        "mixed_recall_at_k_nfcorpus",
        "mixed_cross_source_result_rate",
        "mixed_cross_source_top1_rate",
        "mixed_topology_route_source_purity",
        "mixed_topology_route_cross_source_rate",
        "mixed_topology_route_source_purity_scifact",
        "mixed_topology_route_source_purity_nfcorpus",
        "mixed_topology_relevant_fragment_coverage",
        "mixed_topology_relevant_fragment_hit_rate",
        "mixed_topology_relevant_fragment_coverage_scifact",
        "mixed_topology_relevant_fragment_coverage_nfcorpus",
        "mixed_post_fusion_cross_source_result_rate",
        "mixed_post_fusion_cross_source_top1_rate",
        "mixed_cluster_count",
        "mixed_cluster_singleton_rate",
        "mixed_cluster_shared_rate",
        "mixed_cluster_shared_document_rate",
        "mixed_cluster_weighted_source_purity",
        "mixed_cluster_weighted_source_entropy_bits",
        "mixed_cluster_count_scifact",
        "mixed_cluster_count_nfcorpus",
        "mixed_cluster_cross_source_exposure_scifact",
        "mixed_cluster_cross_source_exposure_nfcorpus",
        "mixed_cluster_overlap_jaccard_nfcorpus_scifact",
        "search_latency_ms_p50",
        "search_latency_ms_p95",
        "topology_narrow_rate",
        "topology_vector_augmentation_avg",
        "topology_confidence_abstain_rate",
        "topology_snapshot_cache_hit_rate",
        "vector_candidate_work_budget_avg",
        "vector_distance_evaluation_budget_avg",
        "vector_ann_candidate_budget_actual_avg",
        "vector_total_exact_distance_evaluations_actual_avg",
        "steady_state_query_rate",
        "candidate_pre_fusion_hit_rate",
        "candidate_pre_fusion_recall",
        "mixed_candidate_pre_fusion_recall_scifact",
        "mixed_candidate_pre_fusion_recall_nfcorpus",
        "mixed_candidate_post_fusion_recall_scifact",
        "mixed_candidate_post_fusion_recall_nfcorpus",
        "mixed_returned_trace_recall_scifact",
        "mixed_returned_trace_recall_nfcorpus",
        "mixed_ranking_loss_query_rate_scifact",
        "mixed_ranking_loss_query_rate_nfcorpus",
        "returned_trace_hit_rate",
        "ranking_loss_query_rate",
        "vector_unique_rescue_rate",
        "recall_at_k_ceiling",
        "ceiling_normalized_returned_recall"
      ]
    }
  ],
  "validate": {
    "require_files": ["metrics.json", "stdout.log", "debug.jsonl"],
    "require_metrics": [
      "mrr",
      "mixed_mrr_scifact",
      "mixed_mrr_nfcorpus",
      "mixed_cross_source_result_rate",
      "mixed_topology_route_source_purity",
      "mixed_topology_relevant_fragment_coverage",
      "mixed_cluster_weighted_source_purity",
      "search_latency_ms_p50"
    ],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": [
      "mrr",
      "ndcg_at_k",
      "recall_at_k",
      "mixed_source_macro_mrr",
      "mixed_source_min_mrr",
      "mixed_source_macro_recall_at_k",
      "mixed_source_min_recall_at_k",
      "mixed_mrr_scifact",
      "mixed_mrr_nfcorpus",
      "mixed_recall_at_k_scifact",
      "mixed_recall_at_k_nfcorpus",
      "mixed_cross_source_result_rate",
      "mixed_cross_source_top1_rate",
      "mixed_topology_route_source_purity",
      "mixed_topology_route_cross_source_rate",
      "mixed_topology_route_source_purity_scifact",
      "mixed_topology_route_source_purity_nfcorpus",
      "mixed_topology_relevant_fragment_coverage",
      "mixed_topology_relevant_fragment_hit_rate",
      "mixed_topology_relevant_fragment_coverage_scifact",
      "mixed_topology_relevant_fragment_coverage_nfcorpus",
      "mixed_post_fusion_cross_source_result_rate",
      "mixed_post_fusion_cross_source_top1_rate",
      "mixed_cluster_count",
      "mixed_cluster_singleton_rate",
      "mixed_cluster_intrinsic_shared_document_rate",
      "mixed_cluster_shared_count",
      "mixed_cluster_shared_rate",
      "mixed_cluster_shared_document_rate",
      "mixed_cluster_weighted_source_purity",
      "mixed_cluster_weighted_source_entropy_bits",
      "mixed_cluster_topology_overlap_membership_rate",
      "mixed_cluster_count_scifact",
      "mixed_cluster_count_nfcorpus",
      "mixed_cluster_exclusive_count_scifact",
      "mixed_cluster_exclusive_count_nfcorpus",
      "mixed_cluster_cross_source_exposure_scifact",
      "mixed_cluster_cross_source_exposure_nfcorpus",
      "mixed_cluster_overlap_jaccard_nfcorpus_scifact",
      "search_latency_ms_p50",
      "search_latency_ms_p95",
      "topology_narrow_rate",
      "topology_vector_augmentation_avg",
      "topology_confidence_abstain_rate",
      "topology_snapshot_cache_hit_rate",
      "vector_candidate_work_budget_avg",
      "vector_distance_evaluation_budget_avg",
      "vector_ann_candidate_budget_actual_avg",
      "vector_total_exact_distance_evaluations_actual_avg",
      "steady_state_query_rate",
      "candidate_pre_fusion_hit_rate",
      "candidate_pre_fusion_recall",
      "mixed_candidate_pre_fusion_recall_scifact",
      "mixed_candidate_pre_fusion_recall_nfcorpus",
      "mixed_candidate_post_fusion_recall_scifact",
      "mixed_candidate_post_fusion_recall_nfcorpus",
      "mixed_returned_trace_recall_scifact",
      "mixed_returned_trace_recall_nfcorpus",
      "mixed_ranking_loss_query_rate_scifact",
      "mixed_ranking_loss_query_rate_nfcorpus",
      "returned_trace_hit_rate",
      "ranking_loss_query_rate",
      "vector_unique_rescue_rate",
      "recall_at_k_ceiling",
      "ceiling_normalized_returned_recall"
    ]
  }
}

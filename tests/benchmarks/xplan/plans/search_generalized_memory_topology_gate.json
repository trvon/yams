{
  "name": "search_generalized_memory_topology_gate",
  "description": "Lean single-index generalized-memory gate: compare the topology+ANN product default with a global-ANN control and confident SOAR route-restricted ANN at identical ANN and route budgets.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 7200,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "repeats": 3,
  "baseline": "shadow_margin020_min1",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_BENCH_SEED_SEMANTIC_NEIGHBORS": "1",
      "YAMS_BENCH_TOPOLOGY_ENGINE": "connected",
      "YAMS_TOPOLOGY_MIN_EDGE_SCORE": "0.25",
      "YAMS_TOPOLOGY_MAX_COMPONENT_DOCS": "64",
      "YAMS_VECTOR_MAX_RESULTS": "32",
      "YAMS_VECTOR_SEARCH_ENGINE": "simeon_pq_adc"
    },
    "params": {
      "datasets": ["scifact", "nfcorpus", "fiqa"],
      "documents_per_dataset": 2000,
      "queries_per_dataset": 50,
      "topk": 10,
      "topology_source": "vector",
      "topology_engine": "connected",
      "shared_warm_cache": "generalized_memory_soar_boundary",
      "require_topology_construction_stability": true,
      "require_steady_state": true,
      "seed_semantic_neighbors": "1",
      "max_component_docs": 64,
      "min_edge_score": 0.25
    }
  },
  "arms": [
    {
      "name": "global_ann_c32",
      "factors": {
        "topology_mode": "disabled",
        "ann_candidate_budget": 32,
        "vector_result_budget": 32
      },
      "env": {
        "YAMS_BENCH_TOPOLOGY_MODE": "disabled"
      },
      "params": {
        "require_topology_construction_stability": false
      }
    },
    {
      "name": "shadow_margin020_min1",
      "factors": {
        "topology_mode": "hybrid_assist",
        "topology_vector_policy": "shadow",
        "topology_route_ann_candidate_limit": 64,
        "ann_candidate_budget": 32,
        "vector_result_budget": 32,
        "adaptive_routing": true,
        "confidence_margin": 0.2,
        "min_clusters": 1
      },
      "env": {
        "YAMS_BENCH_TOPOLOGY_MODE": "hybrid_assist",
        "YAMS_BENCH_TOPOLOGY_VECTOR_POLICY": "shadow"
      },
      "params": {
        "topology_vector_policy": "shadow",
        "topology_route_ann_candidate_limit": 64,
        "min_clusters": 1,
        "max_clusters": 4,
        "max_docs": 16,
        "max_seed_documents": 16,
        "adaptive_probe_score_gap": 0.05,
        "narrow_min_boundary_margin": 0.2,
        "min_route_score": 0.15
      }
    },
    {
      "name": "shadow_exact_margin020_min1",
      "factors": {
        "topology_mode": "hybrid_assist",
        "topology_vector_policy": "shadow",
        "topology_route_ann_candidate_limit": 0,
        "ann_candidate_budget": 32,
        "vector_result_budget": 32,
        "adaptive_routing": true,
        "confidence_margin": 0.2,
        "min_clusters": 1
      },
      "env": {
        "YAMS_BENCH_TOPOLOGY_MODE": "hybrid_assist",
        "YAMS_BENCH_TOPOLOGY_VECTOR_POLICY": "shadow"
      },
      "params": {
        "topology_vector_policy": "shadow",
        "topology_route_ann_candidate_limit": 0,
        "min_clusters": 1,
        "max_clusters": 4,
        "max_docs": 16,
        "max_seed_documents": 16,
        "adaptive_probe_score_gap": 0.05,
        "narrow_min_boundary_margin": 0.2,
        "min_route_score": 0.15
      }
    },
    {
      "name": "narrow_soar_lambda1_ratio105",
      "factors": {
        "topology_mode": "hybrid_assist",
        "topology_vector_policy": "narrow",
        "boundary_spill": "soar",
        "boundary_spill_limit": 1,
        "boundary_spill_distance_ratio": 1.05,
        "boundary_spill_residual_penalty": 1.0,
        "ann_candidate_budget": 32,
        "vector_result_budget": 32
      },
      "env": {
        "YAMS_BENCH_TOPOLOGY_MODE": "hybrid_assist",
        "YAMS_BENCH_TOPOLOGY_VECTOR_POLICY": "narrow",
        "YAMS_BENCH_TOPOLOGY_BOUNDARY_SPILL": "1",
        "YAMS_BENCH_TOPOLOGY_BOUNDARY_SPILL_LIMIT": "1",
        "YAMS_BENCH_TOPOLOGY_BOUNDARY_SPILL_DISTANCE_RATIO": "1.05",
        "YAMS_BENCH_TOPOLOGY_BOUNDARY_SPILL_RESIDUAL_PENALTY": "1.0"
      },
      "params": {
        "topology_vector_policy": "narrow",
        "topology_route_ann_candidate_limit": 64,
        "topology_boundary_spill": "1",
        "topology_boundary_spill_limit": 1,
        "topology_boundary_spill_distance_ratio": 1.05,
        "topology_boundary_spill_residual_penalty": 1.0,
        "min_clusters": 1,
        "max_clusters": 4,
        "max_docs": 16,
        "max_seed_documents": 16,
        "adaptive_probe_score_gap": 0.05,
        "narrow_min_boundary_margin": 0.2,
        "min_route_score": 0.15
      }
    }
  ],
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": [
        "mrr",
        "ndcg_at_k",
        "recall_at_k",
        "mixed_source_macro_mrr",

{
  "name": "topology_core_ab",
  "description": "Classic vs topology_core search engine variant A/B on a fixed expansion arm (cap2) and topology source.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 3600,
  "continue_on_arm_failure": true,
  "mode": "live-ish",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_BENCH_SEED_SEMANTIC_NEIGHBORS": "1",
      "YAMS_BENCH_TOPOLOGY_SOURCE": "segment_keyphrase",
      "YAMS_BENCH_TOPOLOGY_ENGINE": "connected"
    },
    "params": {
      "dataset": "synthetic",
      "corpus_size": 50,
      "num_queries": 10,
      "topk": 10,
      "topology_source": "segment_keyphrase",
      "expansion_arm": "cap2",
      "seed_semantic_neighbors": "1"
    }
  },
  "factors": {
    "search_engine_variant": ["classic", "topology_core"]
  },
  "steps": [
    {
      "worker": "retrieval_quality",
      "metrics": ["mrr", "ndcg_at_k"]
    }
  ],
  "validate": {
    "require_files": ["metrics.json", "stdout.log"],
    "require_metrics": ["mrr"],
    "require_metric_status": ["ok"]
  },
  "summarize": {
    "primary": [
      "mrr",
      "ndcg_at_k",
      "map",
      "topology_applied",
      "topology_admitted",
      "hybrid_queries"
    ],
    "group_by": ["search_engine_variant"]
  }
}

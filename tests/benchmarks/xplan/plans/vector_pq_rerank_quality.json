{
  "name": "vector_pq_rerank_quality",
  "description": "Topology-disabled 1024d product-hybrid SciFact+NFCorpus single-factor gate for Simeon PQ exact-rerank depth. Promotion requires a positive paired-query bootstrap confidence lower bound, no per-source regression above 0.005, steady-state p50 within 5%, and p95 within 10% of factor 2; exact scan is an exhaustive vector-scoring reference, not a retrieval upper bound or promotion arm. vectors.db metrics describe the cloned product store, not a standalone backend footprint; setup metrics describe warm/restart work after shared seed construction.",
  "build_dir": "build/release",
  "artifact_root": "build/benchmarks",
  "timeout_sec": 10800,
  "continue_on_arm_failure": false,
  "mode": "live-ish",
  "repeats": 3,
  "baseline": "simeon_rerank_2",
  "fixed": {
    "env": {
      "YAMS_TEST_SAFE_SINGLE_INSTANCE": "1",
      "YAMS_SEARCH_STAGE_TRACE": "1",
      "YAMS_ENABLE_ENV_OVERRIDES": "1",
      "YAMS_BENCH_TOPOLOGY_MODE": "disabled",
      "YAMS_VECTOR_MAX_RESULTS": "32",
      "YAMS_SEARCH_LEXICAL_FLOOR_TOPN": "0",
      "YAMS_SEARCH_LEXICAL_FLOOR_BOOST": "0"
    },
    "params": {
      "datasets": ["scifact", "nfcorpus"],
      "documents_per_dataset": 2000,
      "queries_per_dataset": 50,
      "topk": 10,
      "require_steady_state": true,
      "process_resource_contract": "required",
      "shared_warm_cache": "vector_pq_rerank_quality_1024"
    }
  },
  "arms": [
    {
      "name": "simeon_rerank_1",
      "factors": {
        "retrieval": "product_hybrid",
        "vector_engine": "simeon_pq_adc",
        "candidate_generation": "global_adc",
        "rerank_factor": "1"
      },
      "params": {
        "vector_search_engine": "simeon_pq_adc",
        "vector_index_persistence_contract": "required",
        "simeon_pq_rerank_factor": 1,
        "vector_work_observation_contract": {
          "rows_visited": "required",
          "exact_distance_evaluations": "required",
          "ann_candidate_budget": "required"
        }
      }
    },
    {

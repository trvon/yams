# Build artifacts
build/
build-debug/
builddir/
builddir-*/
cmake-build-*/
out/
dist/
target/
coverage/

# Generated coverage artifacts
*.gcov
*.gcda
*.gcno

# Nested build artifacts (subprojects/vendor)
subprojects/*/target/
subprojects/*/build/
subprojects/*/build-*/
subprojects/*/builddir/
subprojects/*/zig-cache/
subprojects/*/zig-out/

# libsql can be checked out locally; keep sources, drop cargo outputs
subprojects/libsql/target/

# Beads task tracking (locked files cause context transfer failures)
.beads/

# CMake cache/presets (generated)
CMakeCache.txt
CMakeFiles/
CMakeUserPresets.json

# Conan caches (keep local; don’t send to Docker context)
.conan/
.conan2/
.conan_cache/
.conan2-local/

# Large local runtime/test outputs
bench_results/
wal/
dispatcher_external/
dispatcher_external_exec/
dispatcher_external_py/
dispatcher_external_trust_file/
dispatcher_external_untrusted/

# Python/Node junk
__pycache__/
.venv/
node_modules/

# IDE
.idea/
.vscode/
.ccls-cache/
.wrangler/
.act/
.crush/

# VCS metadata
.git/

# Unused local mirrors/submodules for image builds
external/
homebrew-yams/

# Fuzzing runtime outputs (often root-owned from containers)
data/fuzz/

# Local logs
ci_logs/
